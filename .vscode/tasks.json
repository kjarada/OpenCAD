{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "command": "bun x webpack --mode development --watch",
      "problemMatcher": {
        "owner": "webpack",
        "severity": "error",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "ERROR in (.+)",
          "file": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "webpack .+ compilin",
          "endsPattern": "webpack .+ compiled"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "bun: watch"
    },
    {
      "type": "shell",
      "command": "bun run build",
      "problemMatcher": ["$ts-webpack"],
      "group": "build",
      "label": "bun: build"
    }
  ]
}

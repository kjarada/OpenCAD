{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2021",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "outDir": "dist/webview",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler"
  },
  "include": ["src/webview/**/*", "src/types/**/*"]
}
